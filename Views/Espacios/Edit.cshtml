@model VetClinic.Models.EspacioDeportivo

@{
    ViewData["Title"] = "Editar Espacio";
}

<h1>Editar Espacio Deportivo</h1>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            
            <div class="form-group mb-3">
                <label asp-for="Nombre" class="control-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="TipoEspacio" class="control-label"></label>
                <input asp-for="TipoEspacio" class="form-control" />
                <span asp-validation-for="TipoEspacio" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Capacidad" class="control-label"></label>
                <input asp-for="Capacidad" class="form-control" type="number" />
                <span asp-validation-for="Capacidad" class="text-danger"></span>
            </div>

            <div class="form-group mt-4">
                <button type="submit" class="btn btn-warning">Actualizar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
